{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "outDir": "dist/main",
    "rootDir": ".",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"],
    "noEmit": false,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["electron/**/*.ts", "src/shared/**/*.ts"]
}